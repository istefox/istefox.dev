---
import ProductPage from '../../layouts/ProductPage.astro';
import CtaRow from '../../components/cleankey/CtaRow.astro';
import { resolveAppcast } from '../../data/appcast';

// Current DMG + version resolved from the Sparkle appcast at build time (shared resolver,
// see src/data/appcast.ts), so the download always matches the latest signed release.
const { dmgUrl, version } = await resolveAppcast();
---

<ProductPage
	title={`Downloading CleanKey ${version}`}
	description="Your CleanKey download is starting."
	productName="CleanKey"
>
	<Fragment slot="head">
		<meta name="robots" content="noindex" />
	</Fragment>

	<section class="dl">
		<div class="spinner" aria-hidden="true"></div>
		<h1>Your download is starting</h1>
		<p class="lead">CleanKey {version} for macOS should begin downloading in a moment.</p>
		<p class="fallback">
			If it does not start, <a id="dmg" href={dmgUrl} download>download CleanKey {version}</a>.
		</p>

		<ol class="steps">
			<li>Open the DMG and drag CleanKey to your Applications folder.</li>
			<li>Launch it from Applications. The icon appears in the menu bar.</li>
			<li>On first run, grant Accessibility so the lock can block the keyboard and trackpad.</li>
		</ol>

		<p class="note">
			The lock is free. A Pro license unlocks keep-awake, AI coding mode, and the end-of-session
			automations.
		</p>

		<CtaRow showDownload={false} proVariant="solid">
			<a class="btn btn-ghost" href="/cleankey">Back to CleanKey</a>
		</CtaRow>
	</section>
</ProductPage>

<script is:inline define:vars={{ dmgUrl }}>
	// Kick off the download shortly after paint. GitHub serves the DMG as an attachment, so the page
	// stays put and the file downloads.
	setTimeout(() => {
		window.location.href = dmgUrl;
	}, 1200);
</script>

<style>
	.dl {
		text-align: center;
		max-width: 34rem;
		margin: 2em auto;
	}
	.dl h1 {
		font-size: 2.2em;
		margin-bottom: 0.3em;
	}
	.lead {
		font-size: 1.15em;
		color: rgb(var(--gray-dark));
	}
	.fallback {
		color: rgb(var(--gray-dark));
	}
	.fallback a {
		color: var(--accent);
		font-weight: 600;
	}
	.spinner {
		width: 40px;
		height: 40px;
		margin: 0 auto 1.2em;
		border-radius: 50%;
		border: 3px solid rgb(var(--gray-light));
		border-top-color: var(--accent);
		animation: spin 0.9s linear infinite;
	}
	@keyframes spin {
		to { transform: rotate(360deg); }
	}
	@media (prefers-reduced-motion: reduce) {
		.spinner { animation: none; }
	}
	.steps {
		text-align: left;
		display: inline-block;
		margin: 1.5em auto;
		padding-left: 1.2em;
		color: rgb(var(--gray-dark));
	}
	.steps li {
		margin-bottom: 0.5em;
	}
	.note {
		color: rgb(var(--gray-dark));
		font-size: 0.95em;
	}
	.dl :global(.cta-row) {
		margin: 1.4em 0 0.6em;
	}
	.btn-ghost {
		color: var(--accent);
		border-color: rgb(var(--gray-light));
	}
	.btn-ghost:hover {
		border-color: var(--accent);
	}
</style>
