---
import { Image } from 'astro:assets';
import ProductPage from '../../layouts/ProductPage.astro';
import CtaRow from '../../components/agentwake/CtaRow.astro';
import PriceBanner from '../../components/agentwake/PriceBanner.astro';
import { resolveAppcast } from '../../data/appcast';
import ogImage from '../../assets/agentwake/og.png';
import {
	HERO,
	META_DESCRIPTION,
	PAIN,
	HOW_IT_KNOWS,
	FEATURE_RULE,
	FREE_FEATURES,
	PRO_FEATURES_LIST,
	AUTOMATIONS,
	COMPARISON_INTRO,
	COMPARISON_COLS,
	COMPARISON_ROWS,
	COMPARISON_FOOTNOTES,
	USE_CASES,
	PRICING_COPY,
	FAQ,
	FOOTER_PRIVACY,
	FOOTER_LINKS,
	SHOT_LIST,
	POLAR_CHECKOUT_URL,
} from '../../data/agentwake';
import { PRICING } from '../../data/pricing';

const hasPolar = POLAR_CHECKOUT_URL !== '';
const { version } = await resolveAppcast();
const chips = [`v${version} · ${HERO.chips[0]}`, ...HERO.chips.slice(1)];

// Real screenshots live in src/assets/agentwake/. Match SHOT_LIST entries by filename so the
// JSON-LD screenshot array and the inline shots pick up new captures automatically.
const shotModules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/agentwake/*.{png,jpg,jpeg,webp,gif}',
	{ eager: true },
);
const shotImages: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(shotModules)) {
	const name = path.split('/').pop();
	if (name) shotImages[name] = mod.default;
}
// Two shots are embedded inline where they prove the claim; the rest feed JSON-LD only.
const inlineShot = (key: string) => {
	const shot = SHOT_LIST.find((s) => s.key === key);
	const img = shotImages[key];
	return shot && img ? { shot, img } : null;
};
const howShot = inlineShot('ai-coding-mode.png');
const finishShot = inlineShot('automations-pane.png');

// Minimal monoline icons (inline SVG, currentColor). No external assets, CSP-safe.
const PATHS: Record<string, string> = {
	bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8z"/>',
	columns: '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 3v18"/>',
	sparkles:
		'<path d="M12 3l1.7 4.8L18.5 9l-4.8 1.7L12 15.5l-1.7-4.8L5.5 9l4.8-1.7z"/><path d="M19 14l.6 1.8 1.9.6-1.9.6-.6 1.9-.6-1.9-1.9-.6 1.9-.6z"/>',
	loop: '<path d="M17 2l4 4-4 4"/><path d="M3 11v-1a4 4 0 0 1 4-4h14"/><path d="M7 22l-4-4 4-4"/><path d="M21 13v1a4 4 0 0 1-4 4H3"/>',
	trophy: '<path d="M8 21h8M12 17v4M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 6H4v1a3 3 0 0 0 3 3M17 6h3v1a3 3 0 0 1-3 3"/>',
	users:
		'<circle cx="9" cy="8" r="3"/><path d="M2.5 20c0-3.3 3-5 6.5-5s6.5 1.7 6.5 5"/><path d="M16 3.6a3 3 0 0 1 0 5.8M21.5 20c0-2.4-1.4-3.9-3.5-4.6"/>',
	image: '<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M4 17l5-5 4 4 3-3 4 4"/>',
	help: '<circle cx="12" cy="12" r="9"/><path d="M9.5 9.2a2.5 2.5 0 1 1 3.6 2.3c-.9.5-1.1.9-1.1 1.8"/><circle cx="12" cy="17" r=".7" fill="currentColor" stroke="none"/>',
	download: '<path d="M12 3v12M7 10l5 5 5-5"/><path d="M4 21h16"/>',
	bell: '<path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M10.5 21a1.5 1.5 0 0 0 3 0"/>',
	terminal: '<rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 9l3 3-3 3M13 15h4"/>',
	lock: '<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/>',
	moon: '<path d="M20 14a8 8 0 1 1-9-11 6 6 0 0 0 9 11z"/>',
	check: '<path d="M4 12l5 5L20 6"/>',
	cross: '<path d="M6 6l12 12M18 6L6 18"/>',
	flame: '<path d="M12 2s5 4.6 5 9.5a5 5 0 0 1-10 0C7 8.7 9 6.6 9 4.5c1 .8 1.7 1.8 2 3C11.6 5.7 12 4 12 2z"/>',
	keyboard: '<rect x="2" y="7" width="20" height="10" rx="2"/><path d="M6 11h.01M10 11h.01M14 11h.01M18 11h.01M7 14h10"/>',
	link: '<path d="M10 14a5 5 0 0 0 7 0l3-3a5 5 0 0 0-7-7l-1.5 1.5"/><path d="M14 10a5 5 0 0 0-7 0l-3 3a5 5 0 0 0 7 7l1.5-1.5"/>',
};
const icon = (name: string) =>
	`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${PATHS[name] ?? ''}</svg>`;
const ACTION_ICON: Record<string, string> = {
	Notify: 'bell',
	'Run Shortcut': 'terminal',
	Lock: 'lock',
	Sleep: 'moon',
};
const USECASE_ICON: Record<string, string> = {
	'Agents overnight': 'moon',
	'Renders and backups': 'bolt',
	Presentations: 'image',
	'Cleaning the keyboard': 'keyboard',
};

const SITE = Astro.site ?? new URL('https://istefox.dev');
const ogImageURL = new URL(ogImage.src, SITE).toString();

// JSON-LD. The Pro offer price is the current launch-ladder step (src/data/pricing.ts).
const appLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Agentwake',
	applicationCategory: 'UtilitiesApplication',
	operatingSystem: 'macOS 14.0 or later',
	description: META_DESCRIPTION,
	url: new URL('/agentwake', SITE).toString(),
	image: ogImageURL,
	screenshot: SHOT_LIST.slice(1).flatMap((s) => {
		const img = shotImages[s.key];
		return img ? [new URL(img.src, SITE).toString()] : [];
	}),
	softwareVersion: version,
	downloadUrl: new URL('/agentwake/download', SITE).toString(),
	author: { '@type': 'Person', name: 'Stefano Ferri', url: SITE.toString() },
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'EUR',
			url: new URL('/agentwake/download', SITE).toString(),
		},
		{
			'@type': 'Offer',
			name: 'Pro',
			price: PRICING.priceNumeric,
			priceCurrency: 'EUR',
			url: POLAR_CHECKOUT_URL || undefined,
		},
	],
};
// FAQ rich results, generated from the same FAQ array that renders the page section.
const faqLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: FAQ.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
};
const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'istefox.dev', item: SITE.toString() },
		{ '@type': 'ListItem', position: 2, name: 'Agentwake', item: new URL('/agentwake', SITE).toString() },
	],
};
---

<ProductPage
	title="Agentwake for macOS: keep your Mac awake for AI agents"
	description={META_DESCRIPTION}
	productName="Agentwake"
	image={ogImage}
	imageAlt="Agentwake knows when your unattended work is done"
	ctaHref="/agentwake/preview#get"
>
	<Fragment slot="head">
		{/* Parked pre-launch: the full landing lives here unlinked while /agentwake runs the waitlist. */}
		<meta name="robots" content="noindex, nofollow" />
		<link rel="preload" as="image" href="/agentwake/hero-ai-coding-mode-poster.jpg" fetchpriority="high" />
		<script type="application/ld+json" set:html={JSON.stringify(appLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
		{/* Polar embedded checkout. Pinned to an exact version with Subresource Integrity so a CDN
		    compromise cannot inject code into the payment flow. To update: bump the version, then
		    recompute the hash with
		    `curl -s <url> | openssl dgst -sha384 -binary | openssl base64 -A`. */}
		{hasPolar && (
			<script
				src="https://cdn.jsdelivr.net/npm/@polar-sh/checkout@0.1.15/dist/embed.global.js"
				integrity="sha384-cahoDBb6jqcy/nI95rzv3Y/qHhTMk6K/P23HB8wK8Exw/CWv659cFJycoxNkEjEs"
				crossorigin="anonymous"
				defer
				data-auto-init
			></script>
		)}
	</Fragment>

	<PriceBanner slot="banner" />

	<!-- 1. Hero -->
	<section class="hero">
		<h1>{HERO.headline}</h1>
		<p class="subhead">{HERO.subhead}</p>
		<CtaRow />
		<ul class="chips" role="list">
			{chips.map((c) => <li>{c}</li>)}
		</ul>
		<figure class="shot shot-hero">
			<div class="video-wrap">
				<video
					class="hero-video"
					autoplay
					muted
					loop
					playsinline
					preload="metadata"
					poster="/agentwake/hero-ai-coding-mode-poster.jpg"
					aria-label={SHOT_LIST[0].caption}
				>
					<source src="/agentwake/hero-ai-coding-mode.webm" type="video/webm" />
					<source src="/agentwake/hero-ai-coding-mode.mp4" type="video/mp4" />
				</video>
				<button id="video-toggle" class="video-toggle" type="button" data-state="playing" aria-label="Pause video">
					<svg class="ic-pause" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 5v14M15 5v14" /></svg>
					<svg class="ic-play" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M8 5l12 7-12 7z" /></svg>
				</button>
			</div>
			<figcaption>{SHOT_LIST[0].caption}</figcaption>
		</figure>
	</section>

	<!-- 2. The pain -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('flame')} />{PAIN.title}</h2>
		<p>{PAIN.body}</p>
	</section>

	<!-- 3. How it knows -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('sparkles')} />{HOW_IT_KNOWS.title}</h2>
		<p>{HOW_IT_KNOWS.body[0]}</p>
		{
			howShot && (
				<figure class="shot shot-inline">
					<Image
						class="shot-img"
						src={howShot.img}
						alt={howShot.shot.title ?? howShot.shot.caption}
						widths={[375, 750]}
						sizes="(min-width: 640px) 640px, 100vw"
						loading="lazy"
					/>
					<figcaption>{howShot.shot.desc ?? howShot.shot.caption}</figcaption>
				</figure>
			)
		}
		<p>{HOW_IT_KNOWS.body[1]}</p>
		<div class="code-wrap">
			<button id="copy-hook" class="copy-btn" type="button">Copy hook setup</button>
			<span id="copy-status" class="sr-only" role="status"></span>
			<pre><code>{HOW_IT_KNOWS.hookJson}</code></pre>
		</div>
	</section>

	<!-- 4. Feature grid: Free / Pro -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('columns')} />Everything in Free, everything in Pro</h2>
		<p class="rule-line">{FEATURE_RULE}</p>
		<div class="cards tiers-grid">
			<div class="card tier-col">
				<h3>Free</h3>
				<ul class="tier-list">
					{FREE_FEATURES.map((f) => <li>{f}</li>)}
				</ul>
			</div>
			<div class="card tier-col">
				<h3>Pro</h3>
				<ul class="tier-list">
					{PRO_FEATURES_LIST.map((f) => <li>{f}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<!-- 5. The finish line -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('loop')} />{AUTOMATIONS.title}</h2>
		{AUTOMATIONS.body.map((p) => <p>{p}</p>)}
		<h3 class="sub">Triggers</h3>
		<ul class="trust">
			{AUTOMATIONS.triggers.map((t) => <li>{t}</li>)}
		</ul>
		<h3 class="sub">Actions, in order</h3>
		<div class="cards">
			{
				AUTOMATIONS.actions.map((a) => (
					<div class="card">
						<h3><span class="cardico" set:html={icon(ACTION_ICON[a.name] ?? 'sparkles')} />{a.name}</h3>
						<p>{a.body}</p>
					</div>
				))
			}
		</div>
		<p class="muted">{AUTOMATIONS.safety}</p>
		{
			finishShot && (
				<figure class="shot shot-inline">
					<Image
						class="shot-img"
						src={finishShot.img}
						alt={finishShot.shot.title ?? finishShot.shot.caption}
						widths={[375, 750]}
						sizes="(min-width: 640px) 640px, 100vw"
						loading="lazy"
					/>
					<figcaption>{finishShot.shot.desc ?? finishShot.shot.caption}</figcaption>
				</figure>
			)
		}
	</section>

	<!-- 6. Comparison -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('trophy')} />The Amphetamine alternative for AI agents, compared honestly</h2>
		<p>{COMPARISON_INTRO}</p>
		<table class="cmp">
			<caption class="sr-only">Feature comparison between Agentwake, Amphetamine, Adrafinil, Agent Caffeine, and Vigil</caption>
			<thead>
				<tr>
					<th scope="col"><span class="sr-only">Feature</span></th>
					{COMPARISON_COLS.map((c, i) => <th scope="col" class={i === 0 ? 'own' : ''}>{c}</th>)}
				</tr>
			</thead>
			<tbody>
				{
					COMPARISON_ROWS.map((row) => (
						<tr>
							<th scope="row" class="row-label">{row.label}</th>
							{row.values.map((v, i) => {
								// Word boundary so "Not documented" or "Partial" stays plain text.
								const yes = /^Yes\b/.test(v);
								const no = /^No\b/.test(v);
								const extra = v.replace(/^(Yes|No)\b\s*/, '');
								return (
									<td class={`${yes ? 'yes' : no ? 'no' : ''}${i === 0 ? ' own' : ''}`} data-label={COMPARISON_COLS[i]}>
										{yes && (
											<>
												<span class="ci ci-yes" set:html={icon('check')} />
												<span class="sr-only">Yes</span>
											</>
										)}
										{no && (
											<>
												<span class="ci ci-no" set:html={icon('cross')} />
												<span class="sr-only">No</span>
											</>
										)}
										{yes || no ? extra && <span class="ci-txt">{extra}</span> : <span class="ci-txt">{v}</span>}
									</td>
								);
							})}
						</tr>
					))
				}
			</tbody>
		</table>
		{COMPARISON_FOOTNOTES.map((p) => <p class="muted">{p}</p>)}
	</section>

	<!-- 7. Use cases -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('users')} />From overnight Claude Code runs to a clean keyboard</h2>
		<div class="cards">
			{
				USE_CASES.map((u) => (
					<div class="card">
						<h3><span class="cardico" set:html={icon(USECASE_ICON[u.title] ?? 'users')} />{u.title}</h3>
						<p>{u.body}</p>
					</div>
				))
			}
		</div>
	</section>

	<!-- 8. Pricing -->
	<section class="block get-block" id="get">
		<h2><span class="h2ico" set:html={icon('download')} />{PRICING_COPY.title}</h2>
		<div class="cards tiers-grid pricing-tiers">
			<div class="card tier-col">
				<h3>{PRICING_COPY.freeName}</h3>
				<p class="tier-price">€0</p>
				<p>{PRICING_COPY.freeBody}</p>
			</div>
			<div class="card tier-col">
				<h3>{PRICING_COPY.proName}</h3>
				<p class="tier-price">
					{PRICING.price}
					{PRICING.price !== PRICING.listPrice && (
						<>
							<s aria-hidden="true">{PRICING.listPrice}</s>
							<span class="sr-only">, list price {PRICING.listPrice}</span>
						</>
					)}
				</p>
				<p>{PRICING_COPY.proBody}</p>
			</div>
		</div>
		<p class="ladder">{PRICING.ladderSentence}</p>
		<CtaRow note={PRICING_COPY.note} />
	</section>

	<!-- 9. FAQ -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('help')} />Frequently asked questions</h2>
		<div class="faq">
			{
				FAQ.map((item) => (
					<details>
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))
			}
		</div>
	</section>

	<!-- 10. Links + privacy -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('link')} />Links</h2>
		<ul class="footer-links" role="list">
			{
				FOOTER_LINKS.map((l) => (
					<li>
						<a href={l.href}>{l.label}</a>
					</li>
				))
			}
		</ul>
		<p class="muted">{FOOTER_PRIVACY}</p>
	</section>
</ProductPage>

<script is:inline>
	(() => {
		const btn = document.getElementById('copy-hook');
		const status = document.getElementById('copy-status');
		if (!btn) return;
		const reset = () => {
			btn.textContent = 'Copy hook setup';
		};
		btn.addEventListener('click', async () => {
			const code = btn.parentElement?.querySelector('code')?.textContent ?? '';
			try {
				await navigator.clipboard.writeText(code);
				btn.textContent = 'Copied!';
				if (status) status.textContent = 'Hook setup copied to the clipboard';
			} catch {
				btn.textContent = 'Copy failed';
				if (status) status.textContent = 'Copy failed';
			}
			setTimeout(reset, 1500);
		});
	})();
</script>

<script is:inline>
	(() => {
		const v = document.querySelector('.hero-video');
		const btn = document.getElementById('video-toggle');
		if (!v || !btn) return;
		const setState = (playing) => {
			btn.dataset.state = playing ? 'playing' : 'paused';
			btn.setAttribute('aria-label', playing ? 'Pause video' : 'Play video');
		};
		v.addEventListener('play', () => setState(true));
		v.addEventListener('pause', () => setState(false));
		btn.addEventListener('click', () => {
			if (v.paused) v.play();
			else v.pause();
		});
		// Respect reduced motion: start paused on the poster frame instead of autoplaying.
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			v.removeAttribute('autoplay');
			v.pause();
			v.currentTime = 0;
		}
		setState(!v.paused);
	})();
</script>

<script is:inline>
	// Section reveal on scroll. Sections stay visible without JS or under reduced motion:
	// the .reveal class (which hides them) is only ever added here.
	(() => {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
		if (!('IntersectionObserver' in window)) return;
		const io = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.isIntersecting) {
						e.target.classList.add('in');
						io.unobserve(e.target);
					}
				}
			},
			{ rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
		);
		for (const b of document.querySelectorAll('.block')) {
			b.classList.add('reveal');
			io.observe(b);
		}
	})();
</script>

<style>
	/* Hero: the glow behind the headline breathes like a sleeping Mac's indicator light —
	   the product's whole story (awake while it codes, asleep after) in one quiet motion. */
	.hero {
		position: relative;
		text-align: center;
		padding: 1.5em 0 2em;
	}
	.hero::before {
		content: '';
		position: absolute;
		left: 50%;
		top: -3em;
		width: min(48em, 110vw);
		height: 26em;
		transform: translateX(-50%);
		background: radial-gradient(
			closest-side at 50% 35%,
			color-mix(in srgb, var(--accent) 18%, transparent),
			transparent
		);
		pointer-events: none;
		z-index: -1;
	}
	@media (prefers-reduced-motion: no-preference) {
		.hero::before {
			animation: breathe 7s ease-in-out infinite;
		}
	}
	@keyframes breathe {
		0%,
		100% {
			opacity: 0.55;
		}
		50% {
			opacity: 1;
		}
	}
	.hero h1 {
		font-size: 2.6em;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin-bottom: 0.3em;
	}
	.subhead {
		font-size: 1.1em;
		color: rgb(var(--gray-dark));
		max-width: 56ch;
		margin: 0 auto 1.4em;
	}
	.chips {
		display: flex;
		gap: 0.5em;
		justify-content: center;
		flex-wrap: wrap;
		list-style: none;
		margin: 1.1em 0 0;
		padding: 0;
	}
	.chips li {
		font-size: 0.82em;
		color: rgb(var(--gray-dark));
		border: 1px solid rgb(var(--gray-light));
		background: rgb(var(--bg-elevated));
		border-radius: 999px;
		padding: 0.25em 0.85em;
	}

	.block {
		margin: 3em 0;
	}
	@media (prefers-reduced-motion: no-preference) {
		.block.reveal {
			opacity: 0;
			transform: translateY(14px);
			transition:
				opacity 0.5s ease,
				transform 0.5s ease;
		}
		.block.reveal.in {
			opacity: 1;
			transform: none;
		}
	}
	.block > h2 {
		display: flex;
		align-items: center;
		gap: 0.4em;
		margin-bottom: 0.5em;
		padding-bottom: 0.25em;
