---
// Pre-launch waitlist page at /agentwake. The full landing is parked at ./preview.astro
// (noindexed, unlinked) until launch; restoring it is a git mv back. Hard rule here:
// no prices, no free/paid framing, no download links — description + waitlist only.
import { Image } from 'astro:assets';
import ProductPage from '../../layouts/ProductPage.astro';
import WaitlistForm from '../../components/agentwake/WaitlistForm.astro';
import ogImage from '../../assets/agentwake/og.png';
import { HERO, PAIN, HOW_IT_KNOWS, SHOT_LIST } from '../../data/agentwake';
import {
	WAITLIST_TITLE,
	WAITLIST_META_DESCRIPTION,
	WAITLIST_SUBHEAD,
	WAITLIST_CHIPS,
	WAITLIST_SHOT_KEYS,
	WAITLIST_USE_CASES,
	WAITLIST_COMPARISON,
	WAITLIST_FAQ,
	WHY_JOIN,
} from '../../data/agentwake-waitlist';

// Same filename-matching pattern as the landing so new captures are picked up automatically.
const shotModules = import.meta.glob<{ default: ImageMetadata }>(
	'../../assets/agentwake/*.{png,jpg,jpeg,webp,gif}',
	{ eager: true },
);
const shotImages: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(shotModules)) {
	const name = path.split('/').pop();
	if (name) shotImages[name] = mod.default;
}
const inlineShots = WAITLIST_SHOT_KEYS.flatMap((key) => {
	const shot = SHOT_LIST.find((s) => s.key === key);
	const img = shotImages[key];
	return shot && img ? [{ shot, img }] : [];
});

// Minimal monoline icons (inline SVG, currentColor), same set as the landing.
const PATHS: Record<string, string> = {
	sparkles:
		'<path d="M12 3l1.7 4.8L18.5 9l-4.8 1.7L12 15.5l-1.7-4.8L5.5 9l4.8-1.7z"/><path d="M19 14l.6 1.8 1.9.6-1.9.6-.6 1.9-.6-1.9-1.9-.6 1.9-.6z"/>',
	users:
		'<circle cx="9" cy="8" r="3"/><path d="M2.5 20c0-3.3 3-5 6.5-5s6.5 1.7 6.5 5"/><path d="M16 3.6a3 3 0 0 1 0 5.8M21.5 20c0-2.4-1.4-3.9-3.5-4.6"/>',
	image: '<rect x="3" y="4" width="18" height="16" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M4 17l5-5 4 4 3-3 4 4"/>',
	help: '<circle cx="12" cy="12" r="9"/><path d="M9.5 9.2a2.5 2.5 0 1 1 3.6 2.3c-.9.5-1.1.9-1.1 1.8"/><circle cx="12" cy="17" r=".7" fill="currentColor" stroke="none"/>',
	bell: '<path d="M18 8a6 6 0 1 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M10.5 21a1.5 1.5 0 0 0 3 0"/>',
	moon: '<path d="M20 14a8 8 0 1 1-9-11 6 6 0 0 0 9 11z"/>',
	bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6l1-8z"/>',
	keyboard:
		'<rect x="2" y="7" width="20" height="10" rx="2"/><path d="M6 11h.01M10 11h.01M14 11h.01M18 11h.01M7 14h10"/>',
	flame:
		'<path d="M12 2s5 4.6 5 9.5a5 5 0 0 1-10 0C7 8.7 9 6.6 9 4.5c1 .8 1.7 1.8 2 3C11.6 5.7 12 4 12 2z"/>',
	trophy: '<path d="M8 21h8M12 17v4M7 4h10v4a5 5 0 0 1-10 0z"/><path d="M7 6H4v1a3 3 0 0 0 3 3M17 6h3v1a3 3 0 0 1-3 3"/>',
	check: '<path d="M4 12l5 5L20 6"/>',
	cross: '<path d="M6 6l12 12M18 6L6 18"/>',
};
const icon = (name: string) =>
	`<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${PATHS[name] ?? ''}</svg>`;
const USECASE_ICON: Record<string, string> = {
	'Agents overnight': 'moon',
	'Renders and backups': 'bolt',
	Presentations: 'image',
	'Cleaning the keyboard': 'keyboard',
};

const SITE = Astro.site ?? new URL('https://istefox.dev');
const ogImageURL = new URL(ogImage.src, SITE).toString();
const canonical = new URL('/agentwake', SITE).toString();

// JSON-LD. Pre-launch: no downloadUrl, no softwareVersion, and a single PreOrder offer
// instead of the priced Free/Pro pair — rich-result eligible without revealing pricing.
const appLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Agentwake',
	applicationCategory: 'UtilitiesApplication',
	operatingSystem: 'macOS 14.0 or later',
	description: WAITLIST_META_DESCRIPTION,
	url: canonical,
	image: ogImageURL,
	screenshot: SHOT_LIST.slice(1).flatMap((s) => {
		const img = shotImages[s.key];
		return img ? [new URL(img.src, SITE).toString()] : [];
	}),
	author: { '@type': 'Person', name: 'Stefano Ferri', url: SITE.toString() },
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'EUR',
		availability: 'https://schema.org/PreOrder',
		url: canonical,
	},
};
// FAQ rich results, generated from the same subset that renders the page section.
const faqLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: WAITLIST_FAQ.map((f) => ({
		'@type': 'Question',
		name: f.q,
		acceptedAnswer: { '@type': 'Answer', text: f.a },
	})),
};
const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'istefox.dev', item: SITE.toString() },
		{ '@type': 'ListItem', position: 2, name: 'Agentwake', item: canonical },
	],
};
---

<ProductPage
	title={WAITLIST_TITLE}
	description={WAITLIST_META_DESCRIPTION}
	productName="Agentwake"
	image={ogImage}
	imageAlt="Agentwake knows when your unattended work is done"
	ctaHref="#waitlist"
	ctaLabel="Join the waitlist"
>
	<Fragment slot="head">
		<link rel="preload" as="image" href="/agentwake/hero-ai-coding-mode-poster.jpg" fetchpriority="high" />
		<script type="application/ld+json" set:html={JSON.stringify(appLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
	</Fragment>

	<!-- 1. Hero -->
	<section class="hero">
		<p class="eyebrow">Coming soon to macOS</p>
		<h1>{HERO.headline}</h1>
		<p class="subhead">{WAITLIST_SUBHEAD}</p>
		<a class="btn btn-primary hero-cta" href="#waitlist">Join the waitlist</a>
		<ul class="chips" role="list">
			{WAITLIST_CHIPS.map((c) => <li>{c}</li>)}
		</ul>
		<figure class="shot shot-hero">
			<div class="video-wrap">
				<video
					class="hero-video"
					autoplay
					muted
					loop
					playsinline
					preload="metadata"
					poster="/agentwake/hero-ai-coding-mode-poster.jpg"
					aria-label={SHOT_LIST[0].caption}
				>
					<source src="/agentwake/hero-ai-coding-mode.webm" type="video/webm" />
					<source src="/agentwake/hero-ai-coding-mode.mp4" type="video/mp4" />
				</video>
				<button id="video-toggle" class="video-toggle" type="button" data-state="playing" aria-label="Pause video">
					<svg class="ic-pause" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 5v14M15 5v14" /></svg>
					<svg class="ic-play" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><path d="M8 5l12 7-12 7z" /></svg>
				</button>
			</div>
			<figcaption>{SHOT_LIST[0].caption}</figcaption>
		</figure>
	</section>

	<!-- 2. The pain -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('flame')} />{PAIN.title}</h2>
		<p>{PAIN.body}</p>
	</section>

	<!-- 3. How it knows -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('sparkles')} />{HOW_IT_KNOWS.title}</h2>
		<p>{HOW_IT_KNOWS.body[0]}</p>
	</section>

	<!-- 4. A first look -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('image')} />A first look</h2>
		<div class="shots-grid">
			{
				inlineShots.map(({ shot, img }) => (
					<figure class="shot shot-inline">
						<Image
							class="shot-img"
							src={img}
							alt={shot.title ?? shot.caption}
							widths={[375, 750]}
							sizes="(min-width: 640px) 420px, 100vw"
							loading="lazy"
						/>
						<figcaption>{shot.desc ?? shot.caption}</figcaption>
					</figure>
				))
			}
		</div>
	</section>

	<!-- 5. Use cases -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('users')} />From overnight Claude Code runs to a clean keyboard</h2>
		<div class="cards">
			{
				WAITLIST_USE_CASES.map((u) => (
					<div class="card">
						<h3><span class="cardico" set:html={icon(USECASE_ICON[u.title] ?? 'users')} />{u.title}</h3>
						<p>{u.body}</p>
					</div>
				))
			}
		</div>
	</section>

	<!-- 6. Comparison (minus the Price row) — the strongest signup argument on the page. -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('trophy')} />The Amphetamine alternative for AI agents, compared honestly</h2>
		<p>{WAITLIST_COMPARISON.intro}</p>
		<table class="cmp">
			<caption class="sr-only">Feature comparison between Agentwake, Amphetamine, Adrafinil, Agent Caffeine, and Vigil</caption>
			<thead>
				<tr>
					<th scope="col"><span class="sr-only">Feature</span></th>
					{WAITLIST_COMPARISON.cols.map((c, i) => <th scope="col" class={i === 0 ? 'own' : ''}>{c}</th>)}
				</tr>
			</thead>
			<tbody>
				{
					WAITLIST_COMPARISON.rows.map((row) => (
						<tr>
							<th scope="row" class="row-label">{row.label}</th>
							{row.values.map((v, i) => {
								// Word boundary so "Not documented" or "Partial" stays plain text.
								const yes = /^Yes\b/.test(v);
								const no = /^No\b/.test(v);
								const extra = v.replace(/^(Yes|No)\b\s*/, '');
								return (
									<td class={`${yes ? 'yes' : no ? 'no' : ''}${i === 0 ? ' own' : ''}`} data-label={WAITLIST_COMPARISON.cols[i]}>
										{yes && (
											<>
												<span class="ci ci-yes" set:html={icon('check')} />
												<span class="sr-only">Yes</span>
											</>
										)}
										{no && (
											<>
												<span class="ci ci-no" set:html={icon('cross')} />
												<span class="sr-only">No</span>
											</>
										)}
										{yes || no ? extra && <span class="ci-txt">{extra}</span> : <span class="ci-txt">{v}</span>}
									</td>
								);
							})}
						</tr>
					))
				}
			</tbody>
		</table>
		{WAITLIST_COMPARISON.footnotes.map((p) => <p class="muted">{p}</p>)}
	</section>

	<!-- 7. Why join + form. The #get alias catches stale /agentwake#get links from the landing era. -->
	<section class="block waitlist-block" id="waitlist">
		<span id="get" class="anchor-alias" aria-hidden="true"></span>
		<h2><span class="h2ico" set:html={icon('bell')} />{WHY_JOIN.title}</h2>
		<ul class="why-join" role="list">
			{WHY_JOIN.bullets.map((b) => <li>{b}</li>)}
		</ul>
		<WaitlistForm />
	</section>

	<!-- 8. FAQ -->
	<section class="block">
		<h2><span class="h2ico" set:html={icon('help')} />Frequently asked questions</h2>
		<div class="faq">
			{
				WAITLIST_FAQ.map((item) => (
					<details>
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))
			}
		</div>
	</section>
</ProductPage>

<script is:inline>
	(() => {
		const v = document.querySelector('.hero-video');
		const btn = document.getElementById('video-toggle');
		if (!v || !btn) return;
		const setState = (playing) => {
			btn.dataset.state = playing ? 'playing' : 'paused';
			btn.setAttribute('aria-label', playing ? 'Pause video' : 'Play video');
		};
		v.addEventListener('play', () => setState(true));
		v.addEventListener('pause', () => setState(false));
		btn.addEventListener('click', () => {
			if (v.paused) v.play();
			else v.pause();
		});
		// Respect reduced motion: start paused on the poster frame instead of autoplaying.
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
			v.removeAttribute('autoplay');
			v.pause();
			v.currentTime = 0;
		}
		setState(!v.paused);
	})();
</script>

<script is:inline>
	// Section reveal on scroll. Sections stay visible without JS or under reduced motion:
	// the .reveal class (which hides them) is only ever added here.
	(() => {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
		if (!('IntersectionObserver' in window)) return;
		const io = new IntersectionObserver(
			(entries) => {
				for (const e of entries) {
					if (e.isIntersecting) {
						e.target.classList.add('in');
						io.unobserve(e.target);
					}
				}
			},
			{ rootMargin: '0px 0px -8% 0px', threshold: 0.05 },
		);
		for (const b of document.querySelectorAll('.block')) {
			b.classList.add('reveal');
			io.observe(b);
		}
	})();
</script>

<style>
	/* Hero: the glow behind the headline breathes like a sleeping Mac's indicator light —
	   the product's whole story (awake while it codes, asleep after) in one quiet motion. */
	.hero {
		position: relative;
		text-align: center;
		padding: 1.5em 0 2em;
	}
	.hero::before {
		content: '';
		position: absolute;
		left: 50%;
		top: -3em;
		width: min(48em, 110vw);
		height: 26em;
		transform: translateX(-50%);
		background: radial-gradient(
			closest-side at 50% 35%,
			color-mix(in srgb, var(--accent) 18%, transparent),
			transparent
		);
		pointer-events: none;
		z-index: -1;
	}
	@media (prefers-reduced-motion: no-preference) {
		.hero::before {
			animation: breathe 7s ease-in-out infinite;
		}
	}
	@keyframes breathe {
		0%,
		100% {
			opacity: 0.55;
		}
		50% {
			opacity: 1;
		}
	}
	.eyebrow {
		display: inline-block;
		font-size: 0.85em;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		border: 1px solid var(--accent-2);
		border-radius: 999px;
		padding: 0.3em 1em;
		margin-bottom: 1em;
	}
	.hero h1 {
		font-size: 2.6em;
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin-bottom: 0.3em;
	}
	.subhead {
		font-size: 1.1em;
		color: rgb(var(--gray-dark));
		max-width: 56ch;
		margin: 0 auto 1.4em;
	}
	.hero-cta {
		display: inline-block;
		padding: 0.7em 1.6em;
		font-weight: 700;
		color: #fff;
		background: var(--accent);
		border: 1px solid var(--accent);
		border-radius: 10px;
		text-decoration: none;
	}
	.hero-cta:hover {
		filter: brightness(1.1);
	}
	.chips {
		display: flex;
		gap: 0.5em;
		justify-content: center;
		flex-wrap: wrap;
		list-style: none;
		margin: 1.1em 0 0;
		padding: 0;
	}
	.chips li {
		font-size: 0.82em;
		color: rgb(var(--gray-dark));
		border: 1px solid rgb(var(--gray-light));
		background: rgb(var(--bg-elevated));
		border-radius: 999px;
		padding: 0.25em 0.85em;
	}

	.block {
		margin: 3em 0;
	}
	@media (prefers-reduced-motion: no-preference) {
		.block.reveal {
			opacity: 0;
			transform: translateY(14px);
			transition:
				opacity 0.5s ease,
				transform 0.5s ease;
		}
		.block.reveal.in {
			opacity: 1;
			transform: none;
		}
	}
	.block > h2 {
		display: flex;
		align-items: center;
		gap: 0.4em;
		margin-bottom: 0.5em;
		padding-bottom: 0.25em;
		border-bottom: 2px solid var(--accent-2);
	}
	.h2ico {
		display: inline-flex;
		color: var(--accent);
		flex: none;
	}
	.cardico {
		display: inline-flex;
		vertical-align: -0.15em;
		margin-right: 0.4em;
		color: var(--accent);
	}
	.muted {
		color: rgb(var(--gray-dark));
		font-size: 0.95em;
	}

	table {
		border-collapse: collapse;
		width: 100%;
	}
	.cmp td,
	.cmp th {
		border-bottom: 1px solid rgb(var(--gray-light));
		padding: 0.5em 0.4em;
		text-align: left;
		vertical-align: top;
		font-size: 0.92em;
	}
	.yes {
		color: #1a9c5b;
		font-weight: 700;
	}
	:root[data-theme='dark'] .yes {
		color: #4bd08a;
	}
	.no {
		color: rgb(var(--gray));
	}
	/* Comparison: fits any width, never scrolls. Stacks into cards on phones. */
	.cmp {
		table-layout: fixed;
	}
	.cmp th:first-child,
	.cmp td:first-child {
		width: 28%;
	}
	.cmp .row-label {
		font-weight: 600;
		font-size: 0.95em;
		text-align: left;
	}
	.cmp thead th:not(:first-child),
	.cmp td {
		text-align: center;
	}
	.cmp .own {
		color: var(--accent);
		font-weight: 700;
	}
	.ci-yes {
		color: #1a9c5b;
	}
	:root[data-theme='dark'] .ci-yes {
		color: #4bd08a;
	}
	.ci-no {
		color: rgb(var(--gray));
	}
	.ci-txt {
		display: block;
		font-size: 0.82em;
		line-height: 1.3;
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 640px) {
		.cmp,
		.cmp tbody,
		.cmp tr,
		.cmp td,
		.cmp th[scope='row'] {
			display: block;
			width: 100%;
		}
		.cmp thead {
			display: none;
		}
		.cmp tr {
			border: 1px solid rgb(var(--gray-light));
			border-radius: 12px;
			padding: 0.5em 0.85em;
			margin-bottom: 1em;
		}
		.cmp td {
			border: none;
			padding: 0.3em 0;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 1em;
			text-align: right;
		}
		.cmp th[scope='row'] {
			text-align: left;
			font-size: 1.05em;
			border-bottom: 1px solid rgb(var(--gray-light));
			margin-bottom: 0.4em;
			padding-bottom: 0.4em;
		}
		.cmp td::before {
			content: attr(data-label);
			color: rgb(var(--gray));
			font-size: 0.9em;
			text-align: left;
		}
		.ci-txt {
			display: inline;
		}
	}

	.cards {
		display: grid;
		gap: 1.25em;
	}
	@media (min-width: 640px) {
		.cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	.card {
		padding: 1.1em 1.3em;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 12px;
		background: rgb(var(--bg-elevated));
		transition:
			border-color 0.15s ease,
			transform 0.15s ease;
	}
	@media (prefers-reduced-motion: no-preference) {
		.card:hover {
			transform: translateY(-2px);
		}
	}
	.card:hover {
		border-color: var(--accent);
	}
	.card h3 {
		display: flex;
		align-items: center;
		margin: 0 0 0.35em;
		font-size: 1.15rem;
	}
	.card p {
		margin: 0;
		font-size: 0.98rem;
		color: rgb(var(--gray-dark));
	}

	.shots-grid {
		display: grid;
		gap: 1.5em;
	}
	@media (min-width: 640px) {
		.shots-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	.shot {
		margin: 0;
	}
	.shot-inline {
		max-width: 640px;
		margin: 0 auto;
	}
	.video-wrap {
		position: relative;
		max-width: 640px;
		margin: 1.5em auto 0.5em;
	}
	.hero-video {
		display: block;
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-radius: 12px;
		border: 1px solid rgb(var(--gray-light));
		background: #000;
	}
	.video-toggle {
		position: absolute;
		right: 0.6em;
		bottom: 0.6em;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.2em;
		height: 2.2em;
		padding: 0;
		border: 1px solid rgba(255, 255, 255, 0.35);
		border-radius: 50%;
		background: rgba(10, 8, 16, 0.65);
		color: #fff;
		cursor: pointer;
	}
	.video-toggle:hover {
		background: rgba(10, 8, 16, 0.85);
	}
	.video-toggle svg {
		width: 1em;
		height: 1em;
	}
	.video-toggle[data-state='playing'] .ic-play,
